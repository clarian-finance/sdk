{
  "name": "clarian-finance/sdk-php",
  "description": "Official PHP SDK for the Clarian Finance API",
  "type": "library",
  "version": "0.4.1",
  "license": "MIT",
  "require": {
    "php": ">=8.1",
    "ext-curl": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "Clarian\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Clarian\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit tests"
  }
}
