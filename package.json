{
  "name": "@clarian-finance/sdk",
  "version": "0.2.0",
  "description": "Official TypeScript SDK for the Clarian Finance API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "llms.txt",
    "README.md",
    "README.pt-BR.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "npx tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "clarian",
    "pix",
    "crypto",
    "fintech",
    "sdk",
    "api",
    "stablecoin",
    "brazil"
  ],
  "author": "Clarian Finance <contact@clarian.finance>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/clarian-finance/sdk.git"
  },
  "homepage": "https://github.com/clarian-finance/sdk",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  }
}
